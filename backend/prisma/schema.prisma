generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Vehicle {
  id              Int      @id @default(autoincrement())
  vin             String?
  brand           String
  year            Int
  model           String
  trim            String?
  transmission    String?
  status          String   @default("Available")
  mileage         Int?
  condition       String?
  price           Float?
  description     String?
  image           String?
  images          String?
  videos          String?
  fuelType        String?
  engineCapacity  String?
  drivetrain      String?
  exteriorColor   String?
  interiorColor   String?
  bodyType        String?
  numberOfOwners  String?
  keys            String?
  regionalSpecs   String?
  sunroof         String?
  lighting        String?
  specialPackages String?
  techFeatures    String?
  purchaseCost    Float?
  shippingCost    Float?
  customsCost     Float?
  maintenanceCost Float?
  otherCosts      Float?
  soldPrice       Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Settings {
  id             Int      @id @default(1)
  whatsappNumber String?
  instagramUrl   String?
  tiktokUrl      String?
  email          String?
  phoneNumber    String?
  address        String?
  aboutUsText    String?
  facebookUrl    String?
  updatedAt      DateTime @updatedAt
}
