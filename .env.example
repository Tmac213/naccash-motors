# Backend Environment Variables
NODE_ENV=development
PORT=5000

# Firebase Configuration
FIREBASE_PROJECT_ID=naccashmotor
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/naccash_motors

# JWT
JWT_SECRET=your_jwt_secret_key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=naccashmotor.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=naccashmotor
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=naccashmotor.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
